---
import Layout from "../layouts/Layout.astro";

const promises = [
  { icon: "🤍", t: "No judgment, ever", d: "You won't find shame here. Not for screen time, not for the tantrum in aisle seven, not for the day you lost it. We're all doing our best with the kid and the nervous system we've got." },
  { icon: "🔬", t: "Science, gently", d: "We read the developmental research so you don't have to — then we translate it into something you can actually do at 6pm on a Wednesday." },
  { icon: "🪞", t: "Real, not perfect", d: "Every idea here has been tested on real kids by real, tired people. If it only works in a calm, well-rested household, it doesn't make the cut." },
  { icon: "🌍", t: "Every kind of family", d: "One parent or four, by birth or by choice, near or far — the tools of kindness belong to all of us." },
];
---

<Layout title="About — Raise Kind" description="Why Raise Kind exists: a warm, no-judgment place for raising kind, brave, whole humans.">
  <section class="about-hero">
    <div class="wrap-narrow">
      <p class="eyebrow">Our promise</p>
      <h1>We're not here to make you a <em>perfect</em> parent.</h1>
      <p class="lede">
        We're here to help you raise a <strong>kind</strong> one. And to remind you,
        on the hard days, that the two are not the same thing — and that you're doing
        far better than the voice in your head says you are.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap-narrow story">
      <p>
        Raise Kind started with a small, stubborn belief: that kindness isn't a personality
        trait some lucky kids are born with. It's a <em>skill</em> — modeled, practiced, and
        built in thousands of ordinary moments. The way we say sorry. The way we name a big
        feeling instead of punishing it. The way we treat the waiter, the sibling, ourselves.
      </p>
      <p>
        Kids are always watching. They learn kindness the way they learn language:
        by soaking up the one that surrounds them. So this whole site is really about
        one question — <strong>what surrounds them?</strong>
      </p>
      <blockquote>
        We can't lecture a child into kindness. We can only let them grow up inside it.
      </blockquote>
      <p>
        No gurus. No guilt. No "sleep experts" charging $400 an hour. Just practical,
        tender, well-researched ideas for raising kind, brave, whole humans — from the
        newborn fog to the teenage eye-roll.
      </p>
    </div>
  </section>

  <section class="section promises-section">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">What you can count on</p>
        <h2>Four promises we keep.</h2>
      </div>
      <div class="promise-grid">
        {promises.map((p) => (
          <div class="promise reveal">
            <span class="promise-icon">{p.icon}</span>
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap-narrow join">
      <h2>Come raise kind with us.</h2>
      <p>The Kind Note lands twice a month with one small, doable idea. That's it. That's the pitch.</p>
      <a href="/#kind-note" class="btn btn-primary">Get the Kind Note →</a>
    </div>
  </section>
</Layout>

<style>
  .about-hero { padding: clamp(3.5rem, 9vw, 6rem) 0 1rem; text-align: center; }
  .about-hero h1 { font-size: clamp(2.3rem, 6.5vw, 4rem); }
  .about-hero h1 em { color: var(--coral-deep); }
  .about-hero .lede { font-size: 1.25rem; color: var(--ink-soft); margin-top: 1.2rem; }
  .story p { font-size: 1.18rem; line-height: 1.75; margin: 1.2rem 0; color: #4a3a34; }
  .story em { color: var(--coral-deep); font-style: italic; }
  .story blockquote {
    font-family: var(--serif); font-style: italic; font-size: clamp(1.5rem, 4vw, 2.1rem);
    line-height: 1.3; color: var(--ink); text-align: center; margin: 2.5rem 0;
    padding: 0 1rem; border: none;
  }
  .sec-head { text-align: center; max-width: 600px; margin: 0 auto 2.5rem; }
  .sec-head h2 { font-size: clamp(1.9rem, 4.5vw, 2.8rem); margin-top: 0.5rem; }
  .promises-section { background: var(--paper-deep); border-block: 1px solid var(--line); }
  .promise-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem; }
  .promise { background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.9rem; box-shadow: var(--shadow); }
  .promise-icon { font-size: 2.2rem; }
  .promise h3 { font-size: 1.35rem; margin: 0.5rem 0; }
  .promise p { color: var(--ink-soft); }
  .join { text-align: center; }
  .join h2 { font-size: clamp(1.9rem, 5vw, 2.8rem); }
  .join p { color: var(--ink-soft); font-size: 1.15rem; margin: 0.8rem 0 1.6rem; }
  @media (max-width: 720px) { .promise-grid { grid-template-columns: 1fr; } }
</style>
