---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
}

const {
  title = "Raise Kind - raising kind humans, one small moment at a time",
  description = "A warm, no-judgment corner of the internet about raising kind, brave, whole humans - from the newborn fog to the teenage eye-roll.",
  image = "/og.png",
  type = "website",
  publishedTime,
  modifiedTime,
  section,
} = Astro.props;

const site = Astro.site ?? new URL("https://raisekind.com");
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(image, site);
const year = new Date().getFullYear();

const nav = [
  { href: "/", label: "Home" },
  { href: "/blog/", label: "Essays" },
  { href: "/#ages", label: "By age" },
  { href: "/about/", label: "About" },
];
const current = Astro.url.pathname;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Raise Kind",
  url: site.href,
  description,
  publisher: { "@type": "Organization", name: "Raise Kind" },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Raise Kind" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Raise Kind" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Raise Kind - raising kind humans, one small moment at a time" />
    {type === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === "article" && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === "article" && section && <meta property="article:section" content={section} />}
    {type === "article" && <meta property="article:author" content="Raise Kind" />}
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Raise Kind" />

    <meta name="theme-color" content="#fbf4ea" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#201a17" media="(prefers-color-scheme: dark)" />

    <link rel="alternate" type="application/rss+xml" title="Raise Kind" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Nunito+Sans:ital,opsz,wght@0,6..12,400;0,6..12,600;0,6..12,700;0,6..12,800;1,6..12,500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- No-flash theme -->
    <script is:inline>
      (function () {
        try {
          var k = "rk-theme";
          var s = localStorage.getItem(k);
          var d = s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
          if (d) document.documentElement.setAttribute("data-theme", "dark");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <header class="site-head">
      <div class="wrap head-inner">
        <a href="/" class="brand" aria-label="Raise Kind home">
          <svg class="sprout" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 21V11" stroke="#567150" stroke-width="2" stroke-linecap="round"/>
            <path d="M12 12C12 12 12 6 6 5C6 5 5 11 12 12Z" fill="#6f8f68"/>
            <path d="M12 13C12 13 12 6 18 6C18 6 19 12 12 13Z" fill="#7ea277"/>
            <circle cx="12" cy="21" r="1.6" fill="#e6a742"/>
          </svg>
          <span>Raise&nbsp;Kind</span>
        </a>

        <nav class="nav" id="nav" aria-label="Primary">
          {nav.map((n) => (
            <a href={n.href} class={current === n.href ? "active" : ""}>{n.label}</a>
          ))}
          <a href="/#kind-note" class="nav-cta">The Kind Note</a>
        </nav>

        <div class="head-actions">
          <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle light and dark theme">
            <svg class="i-sun" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="2"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <svg class="i-moon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          </button>
          <a href="/#kind-note" class="btn btn-primary btn-sm head-sub">The Kind Note</a>
          <button id="nav-toggle" class="icon-btn nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="nav">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap foot-grid">
        <div class="foot-brand">
          <span class="foot-logo">Raise Kind</span>
          <p>Raising kind humans, one small moment at a time. No perfect parents here - just people trying, out loud.</p>
        </div>
        <div class="foot-col">
          <h4>Read</h4>
          <a href="/blog/">All essays</a>
          <a href="/#ages">Browse by age</a>
          <a href="/about/">Our promise</a>
          <a href="/rss.xml">RSS feed</a>
        </div>
        <div class="foot-col">
          <h4>The Kind Note</h4>
          <a href="/#kind-note">A gentle letter, twice a month</a>
          <a href="mailto:hello@raisekind.com">hello@raisekind.com</a>
        </div>
      </div>
      <div class="wrap foot-base">
        <span>© {year} Raise Kind</span>
        <span>Made with warmth, not judgment.</span>
      </div>
    </footer>

    <style>
      .skip { position: absolute; left: -999px; top: 0; background: var(--ink); color: var(--paper); padding: 0.6rem 1rem; border-radius: 0 0 10px 0; z-index: 100; }
      .skip:focus { left: 0; }

      .site-head { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(140%) blur(10px); background: color-mix(in srgb, var(--paper) 82%, transparent); border-bottom: 1px solid var(--line); }
      .head-inner { display: flex; align-items: center; gap: 1.2rem; padding: 0.85rem 0; }
      .brand { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--serif); font-weight: 600; font-size: 1.35rem; color: var(--ink); text-decoration: none; letter-spacing: -0.02em; }
      .brand .sprout { width: 1.5rem; height: 1.5rem; }

      .nav { display: flex; gap: 1.4rem; margin-left: auto; align-items: center; }
      .nav a { color: var(--ink-soft); text-decoration: none; font-weight: 700; font-size: 0.95rem; padding: 0.3rem 0; border-bottom: 2px solid transparent; transition: color 0.15s, border-color 0.15s; }
      .nav a:hover, .nav a.active { color: var(--ink); border-color: var(--coral); }
      .nav .nav-cta { display: none; }

      .head-actions { display: flex; align-items: center; gap: 0.6rem; }
      .icon-btn { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 999px; border: 1.5px solid var(--line); background: var(--paper-2); color: var(--ink); cursor: pointer; transition: border-color 0.15s, color 0.15s, transform 0.15s; }
      .icon-btn:hover { border-color: var(--coral); color: var(--coral-deep); }
      .icon-btn svg { width: 20px; height: 20px; }
      .btn-sm { padding: 0.6rem 1.1rem; font-size: 0.88rem; }
      .nav-toggle { display: none; }

      /* Theme icon swap */
      .i-moon { display: none; }
      :global([data-theme="dark"]) .i-sun { display: none; }
      :global([data-theme="dark"]) .i-moon { display: block; }

      @media (max-width: 820px) {
        .head-sub { display: none; }
        .nav-toggle { display: grid; }
        .nav {
          position: fixed; inset: 0 0 0 auto; width: min(320px, 82vw);
          flex-direction: column; align-items: flex-start; gap: 0.4rem;
          background: var(--paper-2); border-left: 1px solid var(--line);
          padding: 5rem 1.6rem 2rem; margin: 0; z-index: 60;
          transform: translateX(105%); visibility: hidden;
          transition: transform 0.28s cubic-bezier(.4,0,.2,1), visibility 0.28s;
          box-shadow: var(--shadow-lift);
        }
        .nav.open { transform: none; visibility: visible; }
        .nav a { font-size: 1.2rem; font-family: var(--serif); width: 100%; border-bottom: 1px solid var(--line); padding: 0.7rem 0; }
        .nav .nav-cta { display: block; margin-top: 1rem; background: var(--coral); color: #fff; border-radius: 999px; text-align: center; padding: 0.8rem; border: none; }
        .nav-backdrop { position: fixed; inset: 0; background: rgba(30,20,16,0.4); z-index: 55; opacity: 0; pointer-events: none; transition: opacity 0.28s; }
        .nav-backdrop.on { opacity: 1; pointer-events: auto; }
      }

      .site-foot { margin-top: clamp(4rem, 10vw, 7rem); background: var(--paper-deep); border-top: 1px solid var(--line); padding-top: clamp(2.5rem, 6vw, 4rem); }
      .foot-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 2rem; padding-bottom: 2.5rem; }
      .foot-brand p { color: var(--ink-soft); max-width: 34ch; margin-top: 0.6rem; }
      .foot-logo { font-family: var(--serif); font-size: 1.3rem; font-weight: 600; }
      .foot-col h4 { font-family: var(--sans); font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--sage-deep); margin-bottom: 0.7rem; }
      .foot-col a { display: block; color: var(--ink-soft); text-decoration: none; padding: 0.25rem 0; }
      .foot-col a:hover { color: var(--coral-deep); }
      .foot-base { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--line); padding: 1.3rem 0; margin-top: 0.5rem; font-size: 0.9rem; color: var(--ink-faint); }
      @media (max-width: 720px) { .foot-grid { grid-template-columns: 1fr; gap: 1.6rem; } .foot-base { flex-direction: column; gap: 0.4rem; } }
    </style>

    <script>
      // Reveal on scroll
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
        }
      }, { threshold: 0.12 });
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      // Theme toggle
      const key = "rk-theme";
      const toggle = document.getElementById("theme-toggle");
      toggle?.addEventListener("click", () => {
        const isDark = document.documentElement.getAttribute("data-theme") === "dark";
        if (isDark) { document.documentElement.removeAttribute("data-theme"); localStorage.setItem(key, "light"); }
        else { document.documentElement.setAttribute("data-theme", "dark"); localStorage.setItem(key, "dark"); }
      });

      // Mobile nav
      const nav = document.getElementById("nav");
      const navToggle = document.getElementById("nav-toggle");
      let backdrop: HTMLDivElement | null = null;
      function closeNav() {
        nav?.classList.remove("open");
        navToggle?.setAttribute("aria-expanded", "false");
        backdrop?.classList.remove("on");
      }
      navToggle?.addEventListener("click", () => {
        const open = nav?.classList.toggle("open");
        navToggle.setAttribute("aria-expanded", String(!!open));
        if (open && !backdrop) {
          backdrop = document.createElement("div");
          backdrop.className = "nav-backdrop";
          document.body.appendChild(backdrop);
          backdrop.addEventListener("click", closeNav);
        }
        requestAnimationFrame(() => backdrop?.classList.toggle("on", !!open));
      });
      nav?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeNav));
    </script>
  </body>
</html>
